# Core trading settings
SYMBOL=AAPL
WATCHLIST=AAPL,MSFT,NVDA,SPY,QQQ
LOOKBACK_PERIOD=3mo
INTERVAL=1d
PAPER_MODE=true
TRADE_SIZE=1
RISK_PER_TRADE_PCT=0.01
RISK_REWARD=2.0
MAX_DAILY_LOSS=500
STARTING_CASH=10000

# Broker settings (optional for local paper broker)
BROKER_NAME=paper
BROKER_API_KEY=
BROKER_SECRET_KEY=

# Optional: where paper state is persisted
PAPER_STATE_PATH=data/state/paper_state.json
